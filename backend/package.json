{
  "name": "clientforge-ai-backend",
  "version": "0.1.0",
  "description": "ClientForge.ai — Multi-tenant SMS-first lead conversion automation API",
  "main": "src/index.js",
  "scripts": {
    "dev": "nodemon src/index.js",
    "start": "node src/index.js",
    "build:grace-to-grace": "npm install --prefix ../grace-to-grace-web && npm run build --prefix ../grace-to-grace-web",
    "build:frontend": "npm install --prefix ../frontend && npm run build --prefix ../frontend",
    "build:webapps": "npm run build:grace-to-grace && npm run build:frontend",
    "build": "npm run build:webapps",
    "build:valuation-bands": "node scripts/buildVehicleValuationBands.js",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "migrate:status": "knex migrate:status",
    "seed:g2g-owner": "node scripts/seedG2gOwner.js",
    "test": "node scripts/testBookingEmailParse.js && node scripts/testBookingEventClassification.js",
    "seed:cherished-aesthetics": "node scripts/seedCherishedAestheticsServices.js",
    "normalize:tenant-phones": "node scripts/normalizeTenantPhones.js"
  },
  "keywords": [
    "clientforge",
    "saas",
    "sms",
    "automation",
    "leads"
  ],
  "author": "ClientForge.ai",
  "license": "UNLICENSED",
  "private": true,
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "csv-parse": "^6.1.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "imapflow": "^1.3.3",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mailparser": "^3.9.8",
    "morgan": "^1.10.1",
    "multer": "^2.1.0",
    "openai": "^6.25.0",
    "pg": "^8.19.0",
    "resend": "^6.9.3",
    "twilio": "^5.13.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
