# ============================================
# ClientForge.ai — Environment Variables
# Copy this file to .env and fill in real values
# ============================================

NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/leadflow_dev

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# JWT Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# SMS (set SMS_PROVIDER to 'telnyx' or 'twilio')
SMS_MODE=mock
SMS_PROVIDER=twilio

# Twilio (when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_DEFAULT_FROM=

# Telnyx (when SMS_PROVIDER=telnyx)
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_PHONE_NUMBER=

# Database SSL (set to true for hosted databases like Railway, Supabase)
DB_SSL=false

# OpenAI — required for AI follow-up generator and optional inbound SMS auto-replies
OPENAI_API_KEY=

# Public API URL (SMS status callbacks, webhook URLs in Settings)
BASE_URL=http://localhost:3000
