# ============================================
# ClientForge.ai — Environment Variables
# Copy this file to .env and fill in real values
# ============================================

NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/leadflow_dev

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# JWT Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# SMS (set SMS_PROVIDER to 'telnyx' or 'twilio')
SMS_MODE=mock
SMS_PROVIDER=twilio

# Twilio (when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_DEFAULT_FROM=

# Telnyx (when SMS_PROVIDER=telnyx)
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_PHONE_NUMBER=

# Database SSL (set to true for hosted databases like Railway, Supabase)
DB_SSL=false

# OpenAI — required for AI follow-up generator and optional inbound SMS auto-replies
OPENAI_API_KEY=

# Public API URL (SMS status callbacks, webhooks, tracked short links /r/:token)
BASE_URL=http://localhost:3000

# Campaign SMS: rewrite http(s) URLs in body to /r/:token for click tracking (set false to disable)
# TRACK_SMS_HTTP_LINKS=true

# Optional: salt for hashing visitor IP on link clicks (omit to store no IP hash)
# LINK_TRACK_IP_SALT=

# Grace to Grace — Alpha Vantage (ETF proxies SLX / DBB / CPER for metal/scrap blend; optional)
# https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=

# Grace to Grace — "Sell now" on estimate sends an SMS here (E.164 or US 10-digit). Required for that flow in production.
G2G_SELL_NOTIFY_PHONE=

# Optional: tenant UUID used when logging outbound g2g_sell_intent messages (defaults to platform tenant)
# G2G_SELL_INTENT_TENANT_ID=00000000-0000-0000-0000-000000000001

# G2G estimate funnel: each estimate view is stored in g2g_estimate_snapshots.
# Superadmins can list via GET /api/v1/admin/g2g-estimate-snapshots?page=1&limit=50
# Or bookmark (no JWT): GET /api/v1/public/g2g-estimate-snapshots-report?key=...&page=1&limit=50
# Generate a secret: openssl rand -hex 32
# G2G_SNAPSHOTS_REPORT_KEY=
