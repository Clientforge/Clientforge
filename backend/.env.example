# ============================================
# ClientForge.ai — Environment Variables
# Copy this file to .env and fill in real values
# ============================================

NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/leadflow_dev

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# JWT Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Twilio SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Database SSL (set to true for hosted databases like Railway, Supabase)
DB_SSL=false
