# ============================================
# ClientForge.ai — Environment Variables
# Copy this file to .env and fill in real values
# ============================================

NODE_ENV=development
PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://localhost:5432/leadflow_dev

# CORS (frontend URL)
CORS_ORIGIN=http://localhost:5173

# JWT Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# SMS (set SMS_PROVIDER to 'telnyx' or 'twilio')
SMS_MODE=mock
SMS_PROVIDER=twilio

# Twilio (when SMS_PROVIDER=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_DEFAULT_FROM=

# Telnyx (when SMS_PROVIDER=telnyx)
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_PHONE_NUMBER=

# Database SSL (set to true for hosted databases like Railway, Supabase)
DB_SSL=false

# OpenAI — required for AI follow-up generator and optional inbound SMS auto-replies
OPENAI_API_KEY=

# Public API URL (SMS status callbacks, webhooks, tracked short links /r/:token)
BASE_URL=http://localhost:3000

# Campaign SMS: rewrite http(s) URLs in body to /r/:token for click tracking (set false to disable)
# TRACK_SMS_HTTP_LINKS=true

# Optional: salt for hashing visitor IP on link clicks (omit to store no IP hash)
# LINK_TRACK_IP_SALT=

# Grace to Grace — Alpha Vantage (ETF proxies SLX / DBB / CPER for metal/scrap blend; optional)
# https://www.alphavantage.co/support/#api-key
# ALPHA_VANTAGE_API_KEY=

# Grace to Grace — "Sell now" on estimate sends an SMS here (E.164 or US 10-digit). Required for that flow in production.
G2G_SELL_NOTIFY_PHONE=

# Grace to Grace — estimate inquiry SMS (falls back to G2G_SELL_NOTIFY_PHONE if unset)
G2G_ESTIMATE_NOTIFY_PHONE=

# Max one estimate team SMS per customer phone within this window (hours). Photo uploads are not limited.
# G2G_ESTIMATE_SMS_COOLDOWN_HOURS=6

# Optional internal email for estimate inquiries and ready-to-sell alerts
# G2G_ESTIMATE_NOTIFY_EMAIL=team@example.com
# G2G_SELL_NOTIFY_EMAIL=team@example.com

# G2G vehicle photo review — team link after customer uploads photos (falls back to estimate/sell notify phones)
# G2G_PHOTO_NOTIFY_PHONE=
# G2G_PHOTO_NOTIFY_EMAIL=

# Base URL for review links in SMS/email (production app host)
# PUBLIC_APP_BASE_URL=https://app.clientforge-ai.com

# Local disk storage for uploaded vehicle photos (default: backend/uploads/g2g). Use S3/R2 for durable production storage.
# G2G_UPLOAD_DIR=

# Optional: tenant UUID used when logging outbound g2g_sell_intent messages (defaults to platform tenant)
# G2G_SELL_INTENT_TENANT_ID=00000000-0000-0000-0000-000000000001

# Grace to Grace — owner portal (POST /api/v1/g2g-owner/login). Seed: npm run seed:g2g-owner
# G2G_OWNER_USERNAME=owner
# G2G_OWNER_PASSWORD=

# G2G estimate funnel: each estimate view is stored in g2g_estimate_snapshots.
# Superadmins can list via GET /api/v1/admin/g2g-estimate-snapshots?page=1&limit=50
# Or bookmark (no JWT): GET /api/v1/public/g2g-estimate-snapshots-report?key=...&page=1&limit=50
# Generate a secret: openssl rand -hex 32
# G2G_SNAPSHOTS_REPORT_KEY=

# ============================================
# Booking email ingestion (info@clientforge-ai.com)
# Clients forward booking confirmations here → appointments + SMS automations.
# ============================================
BOOKING_INBOX_EMAIL=info@clientforge-ai.com

# Webhook: POST /api/v1/webhook/booking-email (optional secret header x-booking-email-secret)
# BOOKING_EMAIL_WEBHOOK_SECRET=

# Auto-create appointment when parse confidence >= this (0–1)
# BOOKING_EMAIL_MIN_CONFIDENCE=0.55

# IMAP polling (Gmail: imap.gmail.com + app password). Omit to use webhook-only.
# BOOKING_INBOX_IMAP_HOST=imap.gmail.com
# BOOKING_INBOX_IMAP_PORT=993
# BOOKING_INBOX_IMAP_USER=info@clientforge-ai.com
# BOOKING_INBOX_IMAP_PASSWORD=
# BOOKING_INBOX_IMAP_POLL_MS=120000

# Per-tenant routing: add rows to tenant_booking_email_aliases (alias = business name text from email).
# Tenant name is also matched automatically.

# ============================================
# Google Calendar sync (Settings → Integration → Connect Google Calendar)
# Create OAuth credentials at https://console.cloud.google.com/ → Calendar API enabled
# Authorized redirect URI: {BASE_URL}/api/v1/integrations/google-calendar/callback
# ============================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# APP_URL=https://app.clientforge.ai
# GOOGLE_CALENDAR_SYNC_POLL_MS=300000
# GOOGLE_CALENDAR_WATCH_RENEW_MS=3600000
# GOOGLE_TOKEN_ENCRYPTION_KEY=

# ============================================
# Cherished Aesthetics — client onboarding (/cherished-onboarding)
# ============================================
# CHERISHED_TENANT_ID=          # optional if CHERISHED_USER_EMAIL resolves a tenant
# CHERISHED_USER_EMAIL=cherished_aesthetics@outlook.com
# CHERISHED_PORTRAIT_URL=       # Portrait Care patient portal URL for thank-you page
# CHERISHED_ONBOARDING_SEND_WELCOME_SMS=false
# CHERISHED_ONBOARDING_WELCOME_SMS=Hi {firstName}! Welcome to {businessName}. Access your patient portal here: {portraitLink}
