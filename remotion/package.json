{
  "name": "clientforge-explainer",
  "version": "1.0.0",
  "description": "30-second animated explainer video for ClientForge.ai",
  "scripts": {
    "start": "remotion studio src/index.ts",
    "build": "remotion render src/index.ts ClientForgeExplainer out/explainer.mp4",
    "render": "remotion render src/index.ts ClientForgeExplainer",
    "build:medspa": "remotion render src/index.ts MedSpaExplainer out/medspa-explainer.mp4",
    "extract-frames": "node scripts/extract-frames.mjs"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/lottie": "^4.0.434",
    "@remotion/renderer": "^4.0.0",
    "lottie-web": "^5.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "typescript": "^5.0.0"
  }
}
